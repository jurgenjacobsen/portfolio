<%- include('head') %>

<% let today = new Date(); %>

<body>
  <div id="body-1" class="container">
    <div class="aboutme">
      <h1 class="name"><%= config.aboutMe.name %></h1>
      <p class="biograph">
        17-year-old <b>developer</b> and student from Brazil, living at Portugal.
      </p>
      <ul class="social">
        <li><a id="github" href="https://github.com/jurgenjacobsen"><i class='twa twa-dark-github'></i></a></li>
        <li><a id="discord" href="https://discord.gg/GtaxXxNYaD"><i class="twa twa-dark-discord"></i></a></li>
        <li><a id="email" href="mailto:jurgenjacobsen@outlook.com"><i class='twa twa-dark-mail'></i></a></li>
      </ul>
    </div>
    <div class="location">
      <p><span id="date"></span></p>
      <p>It's currently <b id='temperature'> <%= weather.temperature %> °C </b> <%= getSeason((today.getMonth() + 1).toString()) %> (<%= weather.skytext %>) in <b><%= config.cleanLocation %></b>.</p>
    </div>
    <div class="spotify">
      <div class="widget clearfix float-my-children">
        <img src="<%= (nowplaying ? nowplaying.image[3]['#text'] : '/assets/images/noplaying.png') %>"/>
          <div class="info">
            <a href="<%= (nowplaying ? nowplaying.url : 'https://spotify.com') %>" id="spotify-link"><div class="song-title"><%= (nowplaying ? dots(nowplaying.name, 32) : dots('Not listening to anything', 32)) %></div></a>
            <div class="spotify"><i class="twa twa-spotify"></i> Listening to in Spotify</div>
          </div>
      </div>
    </div>
  </div>
  <div id="body-2" class="container">
    <div class="header">
    </div>
    <div class="list">
      <% config.projects.map(project => { %>
        <a href="<%= project.url %>"><div class="project clearfix float-my-children">
          <img src="<%= project.imageURL %>">
          <div class="text">
            <h2><%= project.name %></h2>
            <p><%= project.description %></p>
          </div>
        </div></a>
      <% }); %>
    </div>
  </div>
</body>